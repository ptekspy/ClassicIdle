local byId: { [string]: Types.QuestDefinition } = {}
local indexById: { [string]: number } = {}

for index, quest in quests do
	byId[quest.QuestId] = quest
	indexById[quest.QuestId] = index
end

local Config = {
	Quests = quests,
	FirstQuestId = quests[1].QuestId,
}

function Config.Get(questId: string?): Types.QuestDefinition?
	return if questId then byId[questId] else nil
end

function Config.GetNext(questId: string): Types.QuestDefinition?
	local index = indexById[questId]
	return if index then quests[index + 1] else nil
end

return Config
